{
  "name": "hms-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --forceExit",
    "verify:import-casing": "node scripts/verify-attendance-import-casing.mjs",
    "verify:paths": "node scripts/verify-refactor-paths.mjs",
    "prebuild": "npm run verify:paths && npm run verify:import-casing",
    "test:cov": "jest --coverage",
    "analyze": "ANALYZE=true npm run build",
    "bundle-report": "npm run analyze && echo 'Bundle reports generated at:' && echo '  Client: file://$PWD/.next/analyze/client.html' && echo '  Server: file://$PWD/.next/analyze/nodejs.html'",
    "bundle-size": "npm run build 2>&1 | grep -A 20 'Route (app)' || true"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.16.0",
    "immer": "^10.2.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "postcss": "^8.5.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.0.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.0.5",
    "tailwindcss": "^4.1.10",
    "ts-jest": "^29.0.0",
    "typescript": "^5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp|svg)$": "<rootDir>/__mocks__/fileMock.js",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.ts?(x)",
      "**/?(*.)+(spec|test).ts?(x)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          }
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts",
      "!src/**/*.spec.ts",
      "!src/**/__tests__/**",
      "!src/**/types.ts"
    ]
  }
}
