# Frontend Environment Variables

# Private backend URL used by Server Actions and API route handlers (server-side only).
# Do NOT prefix with NEXT_PUBLIC_ — this value is never sent to the browser.
# For local development: http://localhost:3002
# For production: https://your-railway-app.up.railway.app
API_URL=http://localhost:3002

# Shared secret for server-side auth calls (login/refresh/logout). Must match backend BFF_INTERNAL_SECRET.
# Generate: openssl rand -base64 32
# Required for authentication-protected routes and backend-aligned server calls.
BFF_INTERNAL_SECRET=CHANGE_ME_use_openssl_rand_base64_32_to_generate

# Clinic timezone for calendar "today" and patient defaults (IANA, e.g. America/Sao_Paulo)
NEXT_PUBLIC_CLINIC_TIMEZONE=America/Sao_Paulo

# JWT_SECRET must match the backend value exactly.
# proxy.ts uses it to verify access token signatures on the Edge Runtime (server-side only,
# never exposed to the browser because it lacks the NEXT_PUBLIC_ prefix).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_32_to_generate

# JWT_REFRESH_SECRET is NOT needed in the frontend — refresh tokens are validated by the backend only.
