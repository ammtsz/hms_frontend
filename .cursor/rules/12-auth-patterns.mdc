## BFF Proxy Allowlist (H1)

The catch-all proxy at `src/app/api/[...path]/route.ts` uses an explicit
allowlist of permitted first path segments. Requests for `auth/*` are denied
with 404 to prevent the browser from reaching backend auth endpoints directly.

```typescript
// src/app/api/[...path]/allowlist.ts
export const PROXY_ALLOWED_SEGMENTS = new Set([
  "patients",
  "attendances",
  "consultations",
  "treatments",
  "sessions",
  "schedule-settings",
  "day-finalization",
  "holidays",
  "holiday-templates",
  "settings",
  "timezone",
  "users",
  // ... add new first-segment names here when adding API routes
]);

export function isProxyPathAllowed(segments: string[]): boolean {
  const first = segments[0]?.toLowerCase();
  if (!first || first === "auth") return false;
  return PROXY_ALLOWED_SEGMENTS.has(first);
}
```

### ❌ WRONG: Open relay

```typescript
// NEVER forward every path without checking
const backendUrl = `${BACKEND_URL}/${segments.join("/")}`;
```

