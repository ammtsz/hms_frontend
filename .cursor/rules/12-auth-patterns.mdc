## Server Actions Pattern

### ✅ CORRECT: Use Server Actions

```typescript
// src/app/actions/auth.actions.ts
"use server";

import { cookies } from "next/headers";
import { getBackendUrl } from "@/app/api/lib/getBackendUrl";
import {
  getAccessTokenCookieOptions,
  getRefreshTokenCookieOptions,
} from "@/app/api/lib/authCookieOptions";
import { getBffSecretHeaders } from "@/app/api/lib/getBffSecretHeaders";

const BACKEND_URL = getBackendUrl();

export async function loginAction(credentials: LoginCredentials) {
  const response = await fetch(`${BACKEND_URL}/auth/login`, {
    method: "POST",
    body: JSON.stringify(credentials),
    headers: {
      "Content-Type": "application/json",
      ...getBffSecretHeaders(),
    },
  });

  const { accessToken, refreshToken, user } = await response.json();

  // BFF owns browser cookies — backend returns JSON only
  const cookieStore = await cookies();
  cookieStore.set("access_token", accessToken, getAccessTokenCookieOptions());
  cookieStore.set(
    "refresh_token",
    refreshToken,
    getRefreshTokenCookieOptions(),
  );

  return { success: true, data: user };
}
```

### ❌ WRONG: Client-Side Token Storage

```typescript
// NEVER DO THIS
localStorage.setItem("token", token); // ❌ XSS vulnerable
sessionStorage.setItem("token", token); // ❌ XSS vulnerable
document.cookie = `token=${token}`; // ❌ not httpOnly
```

