## Protected Routes — proxy.ts (NOT middleware.ts)

This project uses Next.js 16's **`src/proxy.ts`** (not `src/middleware.ts`) as
the route interceptor. Renaming it `middleware.ts` will break the build.

```typescript
// src/proxy.ts  ← correct filename for Next.js 16
import { NextResponse } from "next/server";
import type { NextRequest } from "next/server";

export function proxy(request: NextRequest) {
  const { pathname } = request.nextUrl;
  const accessToken = request.cookies.get("access_token")?.value;

  const publicRoutes = ["/login"];
  if (!publicRoutes.includes(pathname) && !accessToken) {
    return NextResponse.redirect(new URL("/login", request.url));
  }
  return NextResponse.next();
}

export const config = {
  matcher: ["/((?!api|_next/static|_next/image|favicon.ico).*)", "/"],
};
```

**Important:** proxy-level redirects are a **UX gate only**. Backend
`JwtAuthGuard` is the authoritative enforcement. Do NOT rely solely on
the proxy for security.

